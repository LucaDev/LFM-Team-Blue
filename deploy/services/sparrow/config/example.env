# Example environment variables for Sparrow Watch-Only
# Bitcoin RPC connection
BITCOIN_RPC_HOST=bitcoind-regtest.btc-net.svc.cluster.local
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=your_rpc_user
BITCOIN_RPC_PASSWORD=your_rpc_password

# Sparrow server settings
SPARROW_SERVER_PORT=8080
SPARROW_SERVER_HOST=0.0.0.0

# Network (regtest for testing)
BITCOIN_NETWORK=regtest