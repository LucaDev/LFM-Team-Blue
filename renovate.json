{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits"],
  "timezone": "Europe/Berlin",
  "labels": ["dependencies", "renovate"],
  "assignees": [],
  "reviewers": [],

  "ignorePaths": ["apphost/.env", "apphost/scripts/**", "apphost/secrets/**"],

  "docker-compose": {
    "managerFilePatterns": [
      "/(^|/)(?:docker-)?compose[^/]*\\.ya?ml$/",
      "/(^|/)apphost/compose/.+\\.ya?ml$/"
    ]
  },

  "packageRules": [
    {
      "description": "Automerge patch & digest updates für Monitoring-Stack",
      "matchManagers": ["docker-compose"],
      "matchPackageNames": [
        "prom/prometheus",
        "prom/alertmanager",
        "prom/node-exporter",
        "grafana/grafana-oss",
        "grafana/loki",
        "grafana/promtail",
        "gcr.io/cadvisor/cadvisor"
      ],
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Kein Auto-Merge für Datenbanken und Storage",
      "matchManagers": ["docker-compose"],
      "matchPackageNames": [
        "postgres",
        "valkey/valkey",
        "redis",
        "dxflrs/garage"
      ],
      "automerge": false,
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Major Updates manuell bestätigen",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-update"],
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Traefik: vorsichtig updaten (Internet-facing)",
      "matchManagers": ["docker-compose"],
      "matchPackageNames": ["traefik"],
      "automerge": false,
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Alpine digest updates automatisch mergen",
      "matchPackageNames": ["/alpine/"],
      "matchUpdateTypes": ["digest"],
      "automerge": true
    }
  ]
}
