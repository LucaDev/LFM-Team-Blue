#!/usr/bin/env bash
set -euo pipefail

# =========================
# Konfiguration
# =========================
MNT="/mnt/usb"

STATE_DIR="/var/lib/psbt-guard"
LOCAL_DIR="$STATE_DIR/identity"

PUB_LOCAL="$LOCAL_DIR/signer-pubkey.asc"
META_LOCAL="$LOCAL_DIR/signer-identity.txt"

DEST_ROOT="$MNT/psbt/identity"
DEST_DIR="$DEST_ROOT/signer"

MANIFEST="$DEST_ROOT/manifest.sha256"

# =========================
# Helper
# =========================
die() { echo "ERROR: $*" >&2; exit 1; }
info() { echo "[*] $*"; }

[[ $EUID -eq 0 ]] || die "Bitte als root ausführen."

# =========================
# 0. Airgap sanity check (ignoriert lo)
# =========================
if ip -o link show | awk -F': ' '{print $2}' | grep -vx "lo" | while read -r ifc; do
  ip link show "$ifc" | grep -q "state UP" && exit 0
done; then
  die "Netzwerk-Interface ist UP (außer lo). Bitte erst airgap aktivieren."
fi

# =========================
# 1. Wechselmedium prüfen
# =========================
if ! mountpoint -q "$MNT"; then
  die "Kein Wechselmedium gemountet unter $MNT"
fi

SRC_DEV="$(findmnt -n -o SOURCE --target "$MNT")"
[[ "$SRC_DEV" =~ ^/dev/ ]] || die "Mountpoint ist kein Blockdevice: $SRC_DEV"

info "Wechselmedium erkannt: $SRC_DEV"

# Optional aber empfehlenswert: Label-Check (falls du PSBTUSB nutzt)
# LABEL="$(lsblk -no LABEL "$SRC_DEV" 2>/dev/null | head -n1 || true)"
# [[ "$LABEL" == "PSBTUSB" ]] || die "Falsches Medium (Label != PSBTUSB)."

# =========================
# 2. Lokale Artefakte prüfen (vom hash-key-gen)
# =========================
[[ -f "$PUB_LOCAL"  ]] || die "Fehlt: $PUB_LOCAL (erst hash-key-gen ausführen)"
[[ -f "$META_LOCAL" ]] || die "Fehlt: $META_LOCAL (erst hash-key-gen ausführen)"

# =========================
# 3. Copy nach Wechselmedium
# =========================
mkdir -p "$DEST_DIR"
chmod 0700 "$DEST_ROOT" "$DEST_DIR" || true

info "Kopiere:"
info " - $PUB_LOCAL  -> $DEST_DIR/"
info " - $META_LOCAL -> $DEST_DIR/"

cp -f "$PUB_LOCAL"  "$DEST_DIR/"
cp -f "$META_LOCAL" "$DEST_DIR/"

# =========================
# 4. Manifest (SHA256) über Identity-Ordner schreiben
# =========================
info "Erzeuge Manifest: $MANIFEST"

(
  cd "$MNT"
  # alle .asc und .txt unter psbt/identity (inkl signer + evtl keyB/keyC)
  find "psbt/identity" -type f \( -name "*.asc" -o -name "*.txt" \) \
    | sort \
    | while read -r f; do sha256sum "$f"; done
) > "$MANIFEST"

chmod 0444 "$MANIFEST" || true

MANIFEST_SHA="$(sha256sum "$MANIFEST" | awk '{print $1}')"
info "Manifest SHA256: $MANIFEST_SHA"

# =========================
# 5. Sync & Unmount
# =========================
sync
info "Daten geschrieben. Hänge Wechselmedium aus…"
umount "$MNT" || die "Konnte $MNT nicht aushängen"

info "FERTIG."
info "Wechselmedium kann jetzt physisch entfernt werden."

export GNUPGHOME=/var/lib/psbt-guard/gnupgexport GNUPGHOME=/var/lib/ps/signer/signer-pubkey.asc