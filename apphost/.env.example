# Domain & Zeitzone
DOMAIN=example.de
ACME_EMAIL=admin@example.de
TZ=Europe/Berlin

# DNS-01 ACME Challenge (valides SSL ohne Internet-Erreichbarkeit!)
# Vollständige Liste: https://doc.traefik.io/traefik/https/acme/#providers
ACME_DNS_PROVIDER=cloudflare

# Hetzner DNS
#HETZNER_API_KEY=CHANGE_THIS

# Cloudflare
CF_DNS_API_TOKEN=CHANGE_THIS_CLOUDFLARE_API_TOKEN

# Immich
IMMICH_DB_PASSWORD=CHANGE_THIS_IMMICH_DB
IMMICH_JWT_SECRET=CHANGE_THIS_MIN_32_CHARS_RANDOM_STRING_HERE
IMMICH_SUBDOMAIN=photos

# Pfad zu deinen Medien auf dem Host (für Jellyfin read-only gemountet)
MEDIA_DIR=/mnt/media

# Paperless-NGX
PAPERLESS_SECRET_KEY=CHANGE_THIS_MIN_50_CHARS_RANDOM_STRING_HERE_NOW
PAPERLESS_OCR_LANGUAGE=deu+eng
PAPERLESS_REDIS_PASSWORD=paperless_redis_internal_8x3k

# OpenCloud (OCIS)
OPENCLOUD_ADMIN_PASSWORD=CHANGE_THIS_OPENCLOUD_ADMIN
OPENCLOUD_SUBDOMAIN=cloud

# Collabora Online
COLLABORA_ADMIN_PASSWORD=CHANGE_THIS_COLLABORA_ADMIN
COLLABORA_SUBDOMAIN=office

# Garage S3
GARAGE_RPC_SECRET=CHANGE_THIS_HEX_SECRET_64CHARS_RUN_OPENSSL_RAND_HEX_32

# Forgejo – Git Forge
# OIDC wird automatisch via forgejo-init eingerichtet (nach update-secrets-authelia.sh).
FORGEJO_SUBDOMAIN=git

# Bichon (rustmailer/bichon)
BICHON_SUBDOMAIN=bichon

# Home Assistant
HOMEASSISTANT_SUBDOMAIN=home

# Homepage Dashboard
HOMEPAGE_SUBDOMAIN=dashboard

# Authelia Single-Sign-On & OIDC-Provider
# Secrets werden automatisch generiert. Ausführen nach Ersteinrichtung und nach Passwortänderung:  scripts/update-secrets-authelia.sh
# Erzeugt: secrets/authelia.env, secrets/authelia_oidc_jwks.pem, secrets/authelia_users.yml
AUTHELIA_SUBDOMAIN=auth
AUTHELIA_ADMIN_USER=admin
AUTHELIA_ADMIN_EMAIL=admin@yourdomain.com
AUTHELIA_ADMIN_PASSWORD=CHANGE_THIS_AUTHELIA_ADMIN_PASSWORD

# Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_GRAFANA_ADMIN
GRAFANA_SECRET_KEY=CHANGE_THIS_GRAFANA_SECRET_KEY_32C
GRAFANA_SUBDOMAIN=grafana

# Ntfy
# Run scripts/update-secrets-ntfy.sh after changing passwords.
NTFY_ADMIN_PASSWORD=CHANGE_THIS_NTFY_ADMIN_PASSWORD
NTFY_ALERTMANAGER_PASSWORD=CHANGE_THIS_NTFY_ALERTMANAGER_PASSWORD
NTFY_SUBDOMAIN=ntfy

# OpenSpeedTest
OPENSPEEDTEST_SUBDOMAIN=speedtest

# Vaultwarden
# ADMIN_TOKEN: Argon2-Hash empfohlen. Erstellen mit:
#   echo -n "DEIN_PASSWORT" | argon2 "$(openssl rand -base64 32)" -e -id -k 65540 -t 3 -p 4
VAULTWARDEN_SUBDOMAIN=vault
VAULTWARDEN_ADMIN_TOKEN=CHANGE_THIS_VAULTWARDEN_ADMIN_TOKEN

# Prometheus
PROMETHEUS_RETENTION=30d

# Mosquitto MQTT
# Passwörter werden via scripts/update-secrets-mosquitto.sh gehasht und in
# secrets/mosquitto.passwd geschrieben. Nach jeder Änderung skript ausführen und mosquitto neu deployen.
MOSQUITTO_SUBDOMAIN=mqtt
# Home Assistant – Vollzugriff auf alle Topics
MQTT_HOMEASSISTANT_PASSWORD=change_me
# Zigbee2MQTT – Zugriff auf zigbee2mqtt/# und homeassistant/#
MQTT_ZIGBEE2MQTT_PASSWORD=change_me
# ESPHome – Zugriff auf esphome/# und homeassistant/#
MQTT_ESPHOME_PASSWORD=change_me
# Nur-Lese-Gast – leseberechtigter Zugriff auf alle Topics (Monitoring)
MQTT_READONLY_PASSWORD=change_me

# Hot-Wallet – Bitcoin-Custody-Stack (btc-hot)
# BTC-Core-RPC-Credentials werden aus HOTWALLET_RPC_PASS_* abgeleitet:
# scripts/update-secrets-hotwallet.sh ausführen, danach hotwallet-btc-core neu
# deployen. ntfy-Alarme laufen über den bestehenden ntfy-Dienst (s.o.) –
# scripts/update-secrets-ntfy.sh legt dafür automatisch den User "hotwallet" an.
# Details: services/hotwallet/README.md, Installationsanleitung Abschnitt "Hot-Wallet".
HOTWALLET_SUBDOMAIN=hotwallet
HOTWALLET_POSTGRES_PASSWORD=CHANGE_THIS_HOTWALLET_POSTGRES_ROOT
HOTWALLET_DB_PASSWORD=CHANGE_THIS_HOTWALLET_DB_APP
HOTWALLET_RPC_PASS_MW=CHANGE_THIS_HOTWALLET_RPC_MIDDLEWARE
HOTWALLET_RPC_PASS_TXB=CHANGE_THIS_HOTWALLET_RPC_TXBUILDER
HOTWALLET_NATS_MW_PASS=CHANGE_THIS_HOTWALLET_NATS_MIDDLEWARE
HOTWALLET_NATS_TXB_PASS=CHANGE_THIS_HOTWALLET_NATS_TXBUILDER
HOTWALLET_NATS_OPERATOR_PASS=CHANGE_THIS_HOTWALLET_NATS_OPERATOR
HOTWALLET_NATS_SETUP_PASS=CHANGE_THIS_HOTWALLET_NATS_SETUP
HOTWALLET_NTFY_PASSWORD=CHANGE_THIS_HOTWALLET_NTFY_PASSWORD

SIGNER_URL=http://10.10.0.2
SIGNER_HMAC_SECRET=CHANGE_THIS_TO_YOUR_HMAC_SECRET

# Onion-Adresse des Hidden Service (ohne Schema, ohne Subdomain).
# Anzeigen: bash scripts/show-onion-address.sh
# WICHTIG: Muss gesetzt sein, damit Authelia/ForwardAuth über Tor funktioniert
# (Authelia bekommt hierüber den Onion-Cookie-Bereich + Access-Control-Regeln).
TOR_DOMAIN=SET_THIS_TO_YOUR_ONION_DOMAIN.onion
